<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Mod"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mod Name"
        android:layout_marginBottom="12dp"
        app:boxBackgroundColor="@color/bg_input">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Version"
        android:layout_marginBottom="12dp"
        app:boxBackgroundColor="@color/bg_input">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="File name (optional)"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/bg_input">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etModFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddMod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Mod"
        app:backgroundTint="@color/accent_primary"
        app:cornerRadius="10dp" />

</LinearLayout>
